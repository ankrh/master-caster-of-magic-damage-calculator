{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$cutoff = (Get-Date).AddHours(-1); $dir = '.playwright-mcp'; if (Test-Path $dir) { Get-ChildItem $dir | Where-Object { $_.LastWriteTime -lt $cutoff } | Remove-Item -Recurse -Force -ErrorAction SilentlyContinue }",
            "shell": "powershell",
            "async": true,
            "statusMessage": "Cleaning up .playwright-mcp..."
          }
        ]
      }
    ]
  }
}
